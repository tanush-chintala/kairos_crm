# Dedicated Supabase project for the CRM (separate from the kairosintern/lead-gen
# project). Get these from Tanush once the project is created on the company account.
SUPABASE_URL=
SUPABASE_KEY=

# Text bot (supabase/functions/sendblue-bot). These live here for local testing;
# in production they are Supabase Edge Function secrets (supabase secrets set).
# Gemini key is shared with the kairosleadgen project. SendBlue issues a key ID
# and secret pair together in its dashboard API settings.
GEMINI_API_KEY=
SENDBLUE_API_KEY_ID=
SENDBLUE_API_SECRET_KEY=
BOT_WEBHOOK_TOKEN=
